<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="pt-BR">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="x-apple-disable-message-reformatting" />
  <meta name="format-detection" content="telephone=no, date=no, address=no, email=no" />
  <title>Evidence Ballet</title>

  <style type="text/css">

    /* ── Reset ─────────────────────────────────────────────────────── */
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; border: 0; height: auto; line-height: 100%; outline: none; text-decoration: none; display: block; }
    body { margin: 0 !important; padding: 0 !important; width: 100% !important; }
    a { color: #A67880; }

    /* ── Google Fonts ───────────────────────────────────────────────── */
    /* Clear Sans — carrega onde suportado; fallback: Arial */
    @import url('https://fonts.googleapis.com/css2?family=Clear+Sans:ital,wght@0,300;0,400;0,700;1,300&display=swap');

    /* ── Fundos ─────────────────────────────────────────────────────── */
    .email-bg   { background-color: #ede8e6; }
    .body-bg    { background-color: #ffffff; }
    .header-bg  { background-color: #A67880; }
    .footer-bg  { background-color: #D9C5C7; }
    .block-bg   { background-color: #D9C5C7; }

    /* ── Responsivo — Mobile (≤ 480px) ─────────────────────────────── */
    @media screen and (max-width: 480px) {

      /* Container ocupa 100% da largura */
      .email-container { width: 100% !important; }

      /* Elementos que viram bloco e tomam largura total */
      .mobile-full {
        width: 100% !important;
        display: block !important;
      }

      /* Padding lateral reduzido para mobile */
      .mobile-pad {
        padding-left: 24px !important;
        padding-right: 24px !important;
      }

      /* Hero image mais baixo no mobile */
      .hero-img {
        height: 200px !important;
        object-fit: cover;
      }

      /* Título menor no mobile */
      .title {
        font-size: 20px !important;
        line-height: 1.35 !important;
      }

      /* Corpo de texto um ponto a mais no mobile */
      .body-text {
        font-size: 15px !important;
      }

      /* Botão CTA ocupa largura total no mobile */
      .cta-wrap {
        width: 100% !important;
        text-align: center !important;
      }
      .cta-wrap td {
        width: 100% !important;
        display: block !important;
      }
      .cta-link {
        display: block !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
      }

    }

  </style>
</head>

<!-- ════════════════════════════════════════════════════════════════════ -->
<!-- INSTRUÇÕES DE USO                                                    -->
<!--                                                                      -->
<!-- Substitua todas as tags {{VARIAVEL}} pelo conteúdo real antes de     -->
<!-- importar no RD Station.                                              -->
<!--                                                                      -->
<!-- Blocos marcados com "OPCIONAL" podem ser removidos inteiros          -->
<!-- quando não forem necessários para aquele email específico.          -->
<!--                                                                      -->
<!-- Variáveis obrigatórias:                                             -->
<!--   Você chegou até aqui — e isso já nos diz muito sobre você.    — texto de preview (50–90 caracteres)           -->
<!--   Bem-vinda, {{nome}}.        — linha principal do email                      -->
<!--   Você chegou até aqui — e isso já nos diz muito sobre você.   — primeiro parágrafo do corpo                   -->
<!--   Conheça nossos produtos     — texto do botão (imperativo curto)             -->
<!--   https://evidenceballet.com.br/collections/all       — link de destino do botão                      -->
<!--   {{url_descadastro}} — gerado automaticamente pelo RD Station      -->
<!--   {{url_ver_navegador}} — gerado automaticamente pelo RD Station    -->
<!--                                                                      -->
<!-- Variáveis opcionais:                                                -->
<!--   {{URL_IMAGEM_HERO}} / Evidence Ballet — dança em movimento                         -->
<!--   A Evidence Ballet nasceu de uma crença simples: quem vive a dança merece roupas à altura do que sente. Peças que acompanham o movimento, que respeitam o corpo, que permitem que você seja inteiramente você — dentro e fora do estúdio. / Somos 100% brasileiras. Cada peça é pensada para quem vive a dança como vocação, não como passatempo. Movimento, precisão, sensibilidade — esses são os pilares que guiam tudo o que fazemos. Nos próximos dias, você vai conhecer melhor o que criamos — e por quê criamos assim.                                 -->
<!--   {{LABEL_BLOCO}} / {{TEXTO_BLOCO}}                                 -->
<!-- ════════════════════════════════════════════════════════════════════ -->

<body class="email-bg" style="margin:0; padding:0; background-color:#ede8e6;">

  <!-- Texto de pré-visualização (invisível no email, aparece no preview da caixa de entrada) -->
  <div style="display:none; max-height:0; overflow:hidden; font-size:1px; line-height:1px; color:#ede8e6; opacity:0;">
    Você chegou até aqui — e isso já nos diz muito sobre você.&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;
  </div>

  <!-- ── WRAPPER EXTERNO ──────────────────────────────────────────────────── -->
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color:#ede8e6;">
    <tr>
      <td align="center" style="padding: 24px 0;">

        <!-- ── CONTAINER 600px ──────────────────────────────────────────── -->
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="600" class="email-container" style="background-color:#ffffff;">


          <!-- ════════════════════════════════════════════════════════════ -->
          <!--  HEADER                                                      -->
          <!-- ════════════════════════════════════════════════════════════ -->
          <tr>
            <td class="header-bg mobile-pad" bgcolor="#A67880" style="background-color:#A67880; padding: 20px 40px;">
              <!-- LOGO BRANCA — upload logo_branca.png no RD Station e substituir a URL abaixo -->
              <img src="data:image/png;base64," alt="EVIDENCE ballet" width="160" style="display:block; max-width:160px; height:auto;">
            </td>
          </tr>


          <!-- ════════════════════════════════════════════════════════════ -->
          <!--  HERO IMAGE — OPCIONAL                                       -->
          <!--  Remover este bloco <tr> inteiro quando não usar imagem      -->
          <!-- ════════════════════════════════════════════════════════════ -->
          <tr>
            <td style="padding:0; line-height:0; font-size:0;">
              <img
                src="https://raw.githubusercontent.com/biamamoreira/evidence-ballet-email-templates/refs/heads/main/capa%20youtube.jpg"
                alt="Evidence Ballet — dança em movimento"
                width="600"
                class="hero-img mobile-full"
                style="display:block; width:100%; max-width:600px; height:260px; object-fit:cover;"
              >
            </td>
          </tr>


          <!-- ════════════════════════════════════════════════════════════ -->
          <!--  CORPO                                                       -->
          <!-- ════════════════════════════════════════════════════════════ -->
          <tr>
            <td class="body-bg mobile-pad" bgcolor="#ffffff" style="background-color:#ffffff; padding: 40px 48px 16px;">

              <!-- Título principal -->
              <h1
                class="title"
                style="font-family:'Clear Sans',Arial,sans-serif; font-size:24px; font-weight:400; color:#A67880; line-height:1.4; margin:0 0 24px; padding:0;"
              >
                Bem-vinda, {{nome}}.
              </h1>

              <!-- Parágrafo 1 — obrigatório -->
              <p
                class="body-text"
                style="font-family:'Clear Sans',Arial,sans-serif; font-size:15px; font-weight:300; color:#595959; line-height:1.8; margin:0 0 16px;"
              >
                Você chegou até aqui — e isso já nos diz muito sobre você.
              </p>

              <!-- Parágrafo 2 — OPCIONAL: remover se não usar -->
              <p
                class="body-text"
                style="font-family:'Clear Sans',Arial,sans-serif; font-size:15px; font-weight:300; color:#595959; line-height:1.8; margin:0 0 16px;"
              >
                A Evidence Ballet nasceu de uma crença simples: quem vive a dança merece roupas à altura do que sente. Peças que acompanham o movimento, que respeitam o corpo, que permitem que você seja inteiramente você — dentro e fora do estúdio.
              </p>

              <!-- Parágrafo 3 — OPCIONAL: remover se não usar -->
              <p
                class="body-text"
                style="font-family:'Clear Sans',Arial,sans-serif; font-size:15px; font-weight:300; color:#595959; line-height:1.8; margin:0 0 32px;"
              >
                Somos 100% brasileiras. Cada peça é pensada para quem vive a dança como vocação, não como passatempo. Movimento, precisão, sensibilidade — esses são os pilares que guiam tudo o que fazemos. Nos próximos dias, você vai conhecer melhor o que criamos — e por quê criamos assim.
              </p>

            </td>
          </tr>


          <!-- ════════════════════════════════════════════════════════════ -->
          <!--  BLOCO DE DESTAQUE — OPCIONAL                                -->
          <!--  Usar para: dica técnica (pós-compra), oferta (win-back),   -->
          <!--  argumento extra (carrinho abandonado).                      -->
          <!--  Remover este bloco <tr> inteiro quando não usar.           -->
          <!-- ════════════════════════════════════════════════════════════ -->
          


          <!-- ════════════════════════════════════════════════════════════ -->
          <!--  DIVISOR + CTA                                               -->
          <!-- ════════════════════════════════════════════════════════════ -->
          <tr>
            <td class="mobile-pad" style="padding: 0 48px 48px;">

              <!-- Divisor -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom:32px;">
                <tr>
                  <td style="border-bottom:1px solid #D9C5C7; font-size:0; line-height:0;">&nbsp;</td>
                </tr>
              </table>

              <!-- Botão CTA -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" class="cta-wrap">
                <tr>
                  <td align="center" bgcolor="#A67880" style="border-radius:2px; background-color:#A67880;">
                    <a
                      href="https://www.evidenceballet.com.br"
                      target="_blank"
                      class="cta-link"
                      style="display:inline-block; font-family:'Clear Sans',Arial,sans-serif; font-size:12px; font-weight:700; color:#ffffff; text-decoration:none; padding:14px 40px; letter-spacing:2px; text-transform:uppercase; border-radius:2px; mso-padding-alt:0; text-underline-color:#A67880;"
                    >
                      Conheça nossos produtos
                    </a>
                  </td>
                </tr>
              </table>

            </td>
          </tr>


          <!-- ════════════════════════════════════════════════════════════ -->
          <!--  FOOTER                                                      -->
          <!-- ════════════════════════════════════════════════════════════ -->
          <tr>
            <td class="footer-bg mobile-pad" bgcolor="#D9C5C7" style="background-color:#D9C5C7; padding:28px 48px;">
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">

                <!-- Logo texto no footer -->
                <tr>
                  <td align="center" style="padding-bottom:10px;">
                    <!-- LOGO BLUSH — upload logo_blush.png no RD Station e substituir a URL abaixo -->
                    <img src="data:image/png;base64," alt="EVIDENCE ballet" width="100" style="display:inline-block; max-width:100px; height:auto;">
                  </td>
                </tr>

                <!-- Site -->
                <tr>
                  <td align="center" style="padding-bottom:14px;">
                    <a href="https://evidenceballet.com.br" style="font-family:'Clear Sans',Arial,sans-serif; font-size:11px; font-weight:300; color:#7a6060; text-decoration:none;">
                      evidenceballet.com.br
                    </a>
                  </td>
                </tr>

                <!-- Links de gestão -->
                <tr>
                  <td align="center">
                    <a href="{{url_ver_navegador}}" style="font-family:'Clear Sans',Arial,sans-serif; font-size:10px; color:#9a7878; text-decoration:underline;">
                      ver no navegador
                    </a>
                    <span style="font-family:'Clear Sans',Arial,sans-serif; font-size:10px; color:#c0a8a8;">&nbsp;&middot;&nbsp;</span>
                    <a href="{{url_descadastro}}" style="font-family:'Clear Sans',Arial,sans-serif; font-size:10px; color:#9a7878; text-decoration:underline;">
                      cancelar inscri&ccedil;&atilde;o
                    </a>
                  </td>
                </tr>

              </table>
            </td>
          </tr>


        </table>
        <!-- /Container 600px -->

      </td>
    </tr>
  </table>
  <!-- /Wrapper externo -->

</body>
</html>
